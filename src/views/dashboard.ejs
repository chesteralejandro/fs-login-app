<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<title>Dashboard | MVC Auth App</title>
		<link rel="stylesheet" href="styles/style.css" />
	</head>
	<body>
		<div class="dashboard-container">
			<nav class="navbar">
				<h1 class="logo">MVC Auth App</h1>
				<a href="/logout" class="logout-btn">Logout</a>
			</nav>

			<div class="dashboard-card">
				<h2>Welcome, John 👋</h2>
				<p class="dashboard-subtext">
					You have successfully logged in. This is your dashboard
					area.
				</p>

				<div class="dashboard-info">
					<div class="info-box">
						<h3>Account Status</h3>
						<p>Active</p>
					</div>

					<div class="info-box">
						<h3>Role</h3>
						<p>User</p>
					</div>

					<div class="info-box">
						<h3>Member Since</h3>
						<p>2026</p>
					</div>
				</div>
			</div>
		</div>
	</body>
</html>
